<Window x:Class="VSCodeNodeEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NodeBook - Node.js Notebook Editor" Height="768" Width="1024"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}" 
              BorderThickness="0,0,1,0" BorderBrush="{StaticResource BorderBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Sidebar Header -->
            <Border Grid.Row="0" BorderThickness="0,0,0,1" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    Padding="16,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📁 Explorer" FontSize="14" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <!-- File Tree -->
            <TreeView Grid.Row="1" Name="FileTreeView" 
                      Background="{StaticResource SidebarBrush}"
                      Foreground="{StaticResource TextBrush}"
                      BorderThickness="0"
                      Padding="8">
            </TreeView>

            <!-- Sidebar Footer -->
            <Border Grid.Row="2" BorderThickness="0,1,0,0" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    Padding="8">
                <TextBlock Text="Ready" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
            </Border>
        </Grid>

        <!-- Editor Area -->
        <Grid Grid.Column="1" Background="{StaticResource EditorBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Tab Bar -->
            <Border Grid.Row="0" BorderThickness="0,0,0,1" 
                    BorderBrush="{StaticResource BorderBrush}"
                    Background="{StaticResource BackgroundBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Padding="8,0">
                    <Border Name="TabContainer" BorderThickness="0,0,1,0" 
                            BorderBrush="{StaticResource BorderBrush}" 
                            Padding="8,0">
                        <TextBlock Name="CurrentTabName" Text="No file selected" 
                                   Foreground="{StaticResource TextBrush}"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Editor Content -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- JSON Editor -->
                <Border Grid.Row="0" Grid.Column="0" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Editor Toolbar -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" 
                                    Background="{StaticResource BackgroundBrush}"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    Padding="8" Height="35">
                            <Button Content="➕ Add Cell" 
                                    Style="{StaticResource DarkButtonStyle}"
                                    Margin="0,0,8,0" Name="AddCellBtn"/>
                            <Button Content="▶ Run" 
                                    Style="{StaticResource DarkButtonStyle}"
                                    Margin="0,0,8,0" Name="RunBtn"/>
                            <Button Content="💾 Save" 
                                    Style="{StaticResource DarkButtonStyle}"
                                    Name="SaveBtn"/>
                        </StackPanel>

                        <!-- Editor ScrollViewer -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <StackPanel Name="NotebookCellsPanel" 
                                       Background="{StaticResource EditorBrush}"
                                       Padding="0"/>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>